<%- include('partials/head', { title: 'Review: ' + episode.title }) %>

<div class="mb-6">
  <a href="/" class="text-sm text-indigo-600 hover:underline">&larr; Back to episodes</a>
</div>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold"><%= episode.title %></h1>
    <p class="text-sm text-gray-500 mt-1">
      <% if (episode.guest_name) { %>with <%= episode.guest_name %> &middot; <% } %>
      <%= new Date(episode.created_at).toLocaleDateString() %>
    </p>
  </div>
  <div class="flex gap-3">
    <% if (!episode.blog_post) { %>
      <form action="/episodes/<%= episode.id %>/generate" method="POST">
        <button type="submit" class="px-5 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-medium">
          Generate All Content
        </button>
      </form>
    <% } else { %>
      <form action="/episodes/<%= episode.id %>/publish" method="POST" hx-post="/episodes/<%= episode.id %>/publish" hx-target="#publish-results" hx-swap="innerHTML">
        <button type="submit" class="px-5 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 font-medium">
          Publish Approved
        </button>
      </form>
    <% } %>
  </div>
</div>

<!-- Publish results -->
<div id="publish-results" class="mb-4"></div>

<% if (episode.blog_post) { %>
<!-- Tabs -->
<div class="border-b border-gray-200 mb-6">
  <div class="flex gap-6">
    <button onclick="switchTab('blog')" class="tab-btn active pb-3 border-b-2 border-transparent text-sm font-medium text-gray-500 hover:text-gray-700" id="tab-blog">Blog Post</button>
    <button onclick="switchTab('twitter')" class="tab-btn pb-3 border-b-2 border-transparent text-sm font-medium text-gray-500 hover:text-gray-700" id="tab-twitter">Twitter Thread</button>
    <button onclick="switchTab('linkedin')" class="tab-btn pb-3 border-b-2 border-transparent text-sm font-medium text-gray-500 hover:text-gray-700" id="tab-linkedin">LinkedIn Post</button>
    <button onclick="switchTab('substack')" class="tab-btn pb-3 border-b-2 border-transparent text-sm font-medium text-gray-500 hover:text-gray-700" id="tab-substack">Substack</button>
    <button onclick="switchTab('youtube')" class="tab-btn pb-3 border-b-2 border-transparent text-sm font-medium text-gray-500 hover:text-gray-700" id="tab-youtube">YouTube</button>
  </div>
</div>

<!-- Blog Post Tab -->
<div class="tab-panel active" id="panel-blog">
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold">Blog Post</h2>
      <div class="flex items-center gap-3">
        <span id="status-blog">
          <% if (episode.blog_approved) { %>
            <span class="inline-block px-2 py-1 text-xs font-medium bg-green-100 text-green-800 rounded-full">Approved</span>
          <% } else { %>
            <span class="inline-block px-2 py-1 text-xs font-medium bg-gray-100 text-gray-500 rounded-full">Draft</span>
          <% } %>
        </span>
        <form action="/episodes/<%= episode.id %>/regenerate/blog" method="POST" class="inline">
          <button type="submit" class="text-sm text-indigo-600 hover:underline">Regenerate</button>
        </form>
        <button hx-post="/episodes/<%= episode.id %>/approve/blog" hx-target="#status-blog" hx-swap="innerHTML" class="px-3 py-1 bg-green-600 text-white text-sm rounded-lg hover:bg-green-700">Approve</button>
      </div>
    </div>
    <div class="prose prose-sm max-w-none mb-4 p-4 bg-gray-50 rounded-lg whitespace-pre-wrap"><%= episode.blog_post %></div>
    <details class="mt-4">
      <summary class="text-sm text-gray-500 cursor-pointer hover:text-gray-700">Edit content</summary>
      <form hx-post="/episodes/<%= episode.id %>/edit/blog" hx-target="#status-blog" hx-swap="innerHTML" class="mt-3">
        <textarea name="content" rows="12" class="w-full px-3 py-2 border border-gray-300 rounded-lg font-mono text-sm"><%= episode.blog_post %></textarea>
        <button type="submit" class="mt-2 px-4 py-2 bg-indigo-600 text-white text-sm rounded-lg hover:bg-indigo-700">Save Changes</button>
      </form>
    </details>
  </div>
</div>

<!-- Twitter Thread Tab -->
<div class="tab-panel" id="panel-twitter">
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold">Twitter Thread (<%= twitterThread.length %> tweets)</h2>
      <div class="flex items-center gap-3">
        <% if (!twitterConnected) { %>
          <span class="text-xs text-red-500">Not connected</span>
        <% } %>
        <span id="status-twitter">
          <% if (episode.twitter_approved) { %>
            <span class="inline-block px-2 py-1 text-xs font-medium bg-green-100 text-green-800 rounded-full">Approved</span>
          <% } else { %>
            <span class="inline-block px-2 py-1 text-xs font-medium bg-gray-100 text-gray-500 rounded-full">Draft</span>
          <% } %>
        </span>
        <% if (episode.twitter_published) { %>
          <span class="inline-block px-2 py-1 text-xs font-medium bg-blue-100 text-blue-800 rounded-full">Published</span>
        <% } %>
        <form action="/episodes/<%= episode.id %>/regenerate/twitter" method="POST" class="inline">
          <button type="submit" class="text-sm text-indigo-600 hover:underline">Regenerate</button>
        </form>
        <button hx-post="/episodes/<%= episode.id %>/approve/twitter" hx-target="#status-twitter" hx-swap="innerHTML" class="px-3 py-1 bg-green-600 text-white text-sm rounded-lg hover:bg-green-700">Approve</button>
      </div>
    </div>
    <div class="space-y-3">
      <% twitterThread.forEach((tweet, i) => { %>
        <div class="p-4 bg-gray-50 rounded-lg border-l-4 border-indigo-300">
          <div class="flex justify-between items-start">
            <span class="text-xs text-gray-400 font-mono"><%= i + 1 %>/<%= twitterThread.length %></span>
            <span class="text-xs text-gray-400"><%= tweet.length %>/280</span>
          </div>
          <p class="mt-1 whitespace-pre-wrap"><%= tweet %></p>
        </div>
      <% }) %>
    </div>
    <details class="mt-4">
      <summary class="text-sm text-gray-500 cursor-pointer hover:text-gray-700">Edit thread (JSON)</summary>
      <form hx-post="/episodes/<%= episode.id %>/edit/twitter" hx-target="#status-twitter" hx-swap="innerHTML" class="mt-3">
        <textarea name="content" rows="8" class="w-full px-3 py-2 border border-gray-300 rounded-lg font-mono text-sm"><%= JSON.stringify(twitterThread, null, 2) %></textarea>
        <button type="submit" class="mt-2 px-4 py-2 bg-indigo-600 text-white text-sm rounded-lg hover:bg-indigo-700">Save Changes</button>
      </form>
    </details>
  </div>
</div>

<!-- LinkedIn Post Tab -->
<div class="tab-panel" id="panel-linkedin">
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold">LinkedIn Post</h2>
      <div class="flex items-center gap-3">
        <% if (!linkedinConnected) { %>
          <span class="text-xs text-red-500">Not connected</span>
        <% } %>
        <span id="status-linkedin">
          <% if (episode.linkedin_approved) { %>
            <span class="inline-block px-2 py-1 text-xs font-medium bg-green-100 text-green-800 rounded-full">Approved</span>
          <% } else { %>
            <span class="inline-block px-2 py-1 text-xs font-medium bg-gray-100 text-gray-500 rounded-full">Draft</span>
          <% } %>
        </span>
        <% if (episode.linkedin_published) { %>
          <span class="inline-block px-2 py-1 text-xs font-medium bg-blue-100 text-blue-800 rounded-full">Published</span>
        <% } %>
        <form action="/episodes/<%= episode.id %>/regenerate/linkedin" method="POST" class="inline">
          <button type="submit" class="text-sm text-indigo-600 hover:underline">Regenerate</button>
        </form>
        <button hx-post="/episodes/<%= episode.id %>/approve/linkedin" hx-target="#status-linkedin" hx-swap="innerHTML" class="px-3 py-1 bg-green-600 text-white text-sm rounded-lg hover:bg-green-700">Approve</button>
      </div>
    </div>
    <div class="p-4 bg-gray-50 rounded-lg whitespace-pre-wrap"><%= episode.linkedin_post %></div>
    <p class="text-xs text-gray-400 mt-2"><%= (episode.linkedin_post || '').length %> characters</p>
    <details class="mt-4">
      <summary class="text-sm text-gray-500 cursor-pointer hover:text-gray-700">Edit content</summary>
      <form hx-post="/episodes/<%= episode.id %>/edit/linkedin" hx-target="#status-linkedin" hx-swap="innerHTML" class="mt-3">
        <textarea name="content" rows="8" class="w-full px-3 py-2 border border-gray-300 rounded-lg font-mono text-sm"><%= episode.linkedin_post %></textarea>
        <button type="submit" class="mt-2 px-4 py-2 bg-indigo-600 text-white text-sm rounded-lg hover:bg-indigo-700">Save Changes</button>
      </form>
    </details>
  </div>
</div>

<!-- Substack Tab -->
<div class="tab-panel" id="panel-substack">
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold">Substack Draft</h2>
      <div class="flex items-center gap-3">
        <span id="status-substack">
          <% if (episode.substack_approved) { %>
            <span class="inline-block px-2 py-1 text-xs font-medium bg-green-100 text-green-800 rounded-full">Approved</span>
          <% } else { %>
            <span class="inline-block px-2 py-1 text-xs font-medium bg-gray-100 text-gray-500 rounded-full">Draft</span>
          <% } %>
        </span>
        <button hx-post="/episodes/<%= episode.id %>/approve/substack" hx-target="#status-substack" hx-swap="innerHTML" class="px-3 py-1 bg-green-600 text-white text-sm rounded-lg hover:bg-green-700">Approve</button>
      </div>
    </div>
    <div class="p-4 bg-gray-50 rounded-lg whitespace-pre-wrap mb-4"><%= episode.substack_draft %></div>
    <div class="flex gap-3">
      <button onclick="copyToClipboard()" class="px-4 py-2 bg-orange-500 text-white rounded-lg text-sm hover:bg-orange-600 font-medium">
        Copy to Clipboard
      </button>
      <% if (substackUrl) { %>
        <a href="<%= substackUrl %>/publish" target="_blank" class="px-4 py-2 bg-orange-50 text-orange-700 rounded-lg text-sm hover:bg-orange-100 font-medium">
          Open Substack Editor &rarr;
        </a>
      <% } %>
    </div>
    <details class="mt-4">
      <summary class="text-sm text-gray-500 cursor-pointer hover:text-gray-700">Edit content</summary>
      <form hx-post="/episodes/<%= episode.id %>/edit/substack" hx-target="#status-substack" hx-swap="innerHTML" class="mt-3">
        <textarea name="content" rows="12" class="w-full px-3 py-2 border border-gray-300 rounded-lg font-mono text-sm"><%= episode.substack_draft %></textarea>
        <button type="submit" class="mt-2 px-4 py-2 bg-indigo-600 text-white text-sm rounded-lg hover:bg-indigo-700">Save Changes</button>
      </form>
    </details>
  </div>
</div>

<!-- YouTube Tab -->
<div class="tab-panel" id="panel-youtube">
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold">YouTube Title & Thumbnail Options</h2>
      <div class="flex items-center gap-3">
        <span id="status-youtube">
          <% if (episode.youtube_approved) { %>
            <span class="inline-block px-2 py-1 text-xs font-medium bg-green-100 text-green-800 rounded-full">Approved</span>
          <% } else { %>
            <span class="inline-block px-2 py-1 text-xs font-medium bg-gray-100 text-gray-500 rounded-full">Draft</span>
          <% } %>
        </span>
        <form action="/episodes/<%= episode.id %>/regenerate/youtube" method="POST" class="inline">
          <button type="submit" class="text-sm text-indigo-600 hover:underline">Regenerate</button>
        </form>
        <button hx-post="/episodes/<%= episode.id %>/approve/youtube" hx-target="#status-youtube" hx-swap="innerHTML" class="px-3 py-1 bg-green-600 text-white text-sm rounded-lg hover:bg-green-700">Approve</button>
      </div>
    </div>

    <!-- Title Options -->
    <div class="mb-8">
      <h3 class="text-md font-semibold text-gray-700 mb-3">Title Options (ranked by CTR potential)</h3>
      <div class="space-y-3">
        <% if (youtubeOptions.titles && youtubeOptions.titles.length > 0) { %>
          <% youtubeOptions.titles.forEach((item, i) => { %>
            <div class="p-4 bg-gray-50 rounded-lg border-l-4 border-red-400 flex items-start justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <span class="inline-block w-6 h-6 rounded-full bg-red-100 text-red-700 text-xs font-bold flex items-center justify-center shrink-0"><%= i + 1 %></span>
                  <p class="font-medium text-gray-900"><%= item.title %></p>
                </div>
                <p class="text-xs text-gray-500 ml-8"><%= item.why %></p>
              </div>
              <div class="text-right shrink-0">
                <span class="text-xs text-gray-400"><%= item.title.length %> chars</span>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <p class="text-sm text-gray-400">No title options generated yet.</p>
        <% } %>
      </div>
    </div>

    <!-- Thumbnail Text Options -->
    <div class="mb-4">
      <h3 class="text-md font-semibold text-gray-700 mb-3">Thumbnail Text Options</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        <% if (youtubeOptions.thumbnails && youtubeOptions.thumbnails.length > 0) { %>
          <% youtubeOptions.thumbnails.forEach((item, i) => { %>
            <div class="p-4 bg-gray-50 rounded-lg border border-gray-200">
              <div class="flex items-center gap-2 mb-2">
                <span class="inline-block w-6 h-6 rounded-full bg-red-100 text-red-700 text-xs font-bold flex items-center justify-center shrink-0"><%= i + 1 %></span>
                <p class="font-bold text-lg text-gray-900 tracking-wide"><%= item.text %></p>
              </div>
              <p class="text-xs text-gray-500 ml-8"><%= item.visual %></p>
            </div>
          <% }) %>
        <% } else { %>
          <p class="text-sm text-gray-400">No thumbnail options generated yet.</p>
        <% } %>
      </div>
    </div>

    <details class="mt-4">
      <summary class="text-sm text-gray-500 cursor-pointer hover:text-gray-700">Edit options (JSON)</summary>
      <form hx-post="/episodes/<%= episode.id %>/edit/youtube" hx-target="#status-youtube" hx-swap="innerHTML" class="mt-3">
        <textarea name="content" rows="12" class="w-full px-3 py-2 border border-gray-300 rounded-lg font-mono text-sm"><%= JSON.stringify(youtubeOptions, null, 2) %></textarea>
        <button type="submit" class="mt-2 px-4 py-2 bg-indigo-600 text-white text-sm rounded-lg hover:bg-indigo-700">Save Changes</button>
      </form>
    </details>
  </div>
</div>

<% } else { %>
  <!-- No content generated yet -->
  <div class="bg-white rounded-xl border border-gray-200 p-8 text-center">
    <p class="text-gray-500 mb-4">Transcript uploaded. Ready to generate content.</p>
    <p class="text-sm text-gray-400 mb-6">Claude will create a blog post, Twitter thread, LinkedIn post, Substack draft, and YouTube options from the transcript.</p>
    <form action="/episodes/<%= episode.id %>/generate" method="POST">
      <button type="submit" class="px-6 py-3 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-medium text-lg">
        Generate All Content
      </button>
    </form>
  </div>
<% } %>

<script>
function switchTab(tab) {
  document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.remove('active'));
  document.getElementById('tab-' + tab).classList.add('active');
  document.getElementById('panel-' + tab).classList.add('active');
}

function copyToClipboard() {
  const content = document.querySelector('#panel-substack .bg-gray-50').textContent;
  navigator.clipboard.writeText(content).then(() => {
    alert('Copied to clipboard!');
  });
}
</script>

<%- include('partials/foot') %>
