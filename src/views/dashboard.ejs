<%- include('partials/head', { title: 'Dashboard' }) %>

<div class="flex items-center justify-between mb-8">
  <h1 class="text-3xl font-bold">Episodes</h1>
  <div class="flex gap-3">
    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium <%= twitterConnected ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-500' %>">
      <%= twitterConnected ? '✓' : '○' %> Twitter
    </span>
    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium <%= linkedinConnected ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-500' %>">
      <%= linkedinConnected ? '✓' : '○' %> LinkedIn
    </span>
  </div>
</div>

<!-- Connect buttons -->
<% if (!twitterConnected || !linkedinConnected) { %>
<div class="flex gap-3 mb-6">
  <% if (!twitterConnected) { %>
    <a href="/auth/twitter" class="px-4 py-2 bg-black text-white rounded-lg text-sm hover:bg-gray-800">Connect Twitter/X</a>
  <% } %>
  <% if (!linkedinConnected) { %>
    <a href="/auth/linkedin" class="px-4 py-2 bg-blue-700 text-white rounded-lg text-sm hover:bg-blue-800">Connect LinkedIn</a>
  <% } %>
</div>
<% } %>

<!-- Upload form -->
<div class="bg-white rounded-xl border border-gray-200 p-6 mb-8">
  <h2 class="text-lg font-semibold mb-4">New Episode</h2>
  <form action="/episodes" method="POST" enctype="multipart/form-data" class="space-y-4">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Episode Title *</label>
        <input type="text" name="title" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Guest Name</label>
        <input type="text" name="guest_name" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Recording Date</label>
        <input type="date" name="recording_date" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
      </div>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Transcript File (SRT or TXT) *</label>
      <input type="file" name="transcript" accept=".srt,.txt" required class="w-full px-3 py-2 border border-gray-300 rounded-lg">
    </div>
    <button type="submit" class="px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-medium">
      Upload &amp; Continue
    </button>
  </form>
</div>

<!-- Episode list -->
<% if (episodes.length === 0) { %>
  <p class="text-gray-400 text-center py-12">No episodes yet. Upload a transcript to get started.</p>
<% } else { %>
  <div class="space-y-3">
    <% episodes.forEach(ep => { %>
      <% const hasContent = ep.blog_post || ep.twitter_thread || ep.linkedin_post; %>
      <% const published = ep.twitter_published || ep.linkedin_published; %>
      <div class="bg-white rounded-xl border border-gray-200 p-5 flex items-center justify-between">
        <div>
          <h3 class="font-semibold text-lg"><%= ep.title %></h3>
          <p class="text-sm text-gray-500">
            <% if (ep.guest_name) { %>with <%= ep.guest_name %> &middot; <% } %>
            <%= new Date(ep.created_at).toLocaleDateString() %>
          </p>
        </div>
        <div class="flex items-center gap-3">
          <% if (published) { %>
            <span class="px-2 py-1 text-xs bg-green-100 text-green-800 rounded-full">Published</span>
          <% } else if (hasContent) { %>
            <span class="px-2 py-1 text-xs bg-yellow-100 text-yellow-800 rounded-full">Content Ready</span>
          <% } else { %>
            <span class="px-2 py-1 text-xs bg-gray-100 text-gray-500 rounded-full">Uploaded</span>
          <% } %>
          <a href="/episodes/<%= ep.id %>/review" class="px-4 py-2 bg-indigo-50 text-indigo-700 rounded-lg text-sm font-medium hover:bg-indigo-100">
            <%= hasContent ? 'Review' : 'Generate' %>
          </a>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('partials/foot') %>
